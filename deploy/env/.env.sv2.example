# Copy to deploy/env/.env.sv2 for local SV2 scaffold testing.

# AZCoin RPC credentials used by the future SV2 pool/JD path.
AZCOIND_RPC_USER=rpcuser
AZCOIND_RPC_PASSWORD=rpcpassword

# Internal AZCoin node service coordinates inside docker-compose.sv2.yml.
AZCOIND_HOST=azcoind
AZCOIND_RPC_PORT=8332

# Internal hostnames for the SV2 scaffold services.
SV2_TRANSLATOR_HOST=sv2-translator
SV2_POOL_HOST=sv2-pool
SV2_JD_SERVER_HOST=sv2-jd-server
SV2_ORCHESTRATOR_HOST=sv2-orchestrator

# Ports exposed by placeholder translator and SV2 pool services.
SV2_TRANSLATOR_PORT=34254
SV2_POOL_PORT=34255
