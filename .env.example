# AZCOIN Pool - Environment variables
# Copy to .env and adjust

# Log level (trace, debug, info, warn, error)
RUST_LOG=info,azcoin_pool=debug

# Runtime config is loaded from ./config.toml by default.
# Use deploy/configs/config.example.toml as the base template.
#
# Common overrides:
# DAEMON__JOB_SOURCE_MODE=rpc
# DAEMON__URL=http://127.0.0.1:8332
# DAEMON__RPC_USER=rpcuser
# DAEMON__RPC_PASSWORD=rpcpassword
#
# For node API mode instead:
# DAEMON__JOB_SOURCE_MODE=api
# DAEMON__URL=http://node.example.com:8000
# DAEMON__NODE_API_TOKEN=replace-me
#
# API/Stratum binds if you need non-default ports:
# API__BIND=0.0.0.0
# API__PORT=8080
# STRATUM__BIND=0.0.0.0
# STRATUM__PORT=3333
